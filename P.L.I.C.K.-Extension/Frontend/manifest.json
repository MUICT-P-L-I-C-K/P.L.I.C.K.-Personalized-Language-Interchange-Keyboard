{
  "manifest_version": 3,
  "name": "P.L.I.C.K.",
  "version": "4.0",
  "description": "Detect wrong keyboard layout and provide spell checking for Thai/English",

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "core/keyboard-map.js",
        "core/settings.js",
        "core/api.js",
        "core/sound.js",
        "manual/shortcut.js",
        "core/ui/core.js",
        "core/ui/utils.js",
        "core/ui/selection.js",
        "core/ui/components.js",
        "core/ui/underline.js",
        "core/ui/bubble-convert.js",
        "core/ui/bubble-spell.js",
        "core/ui/bubble-lang.js",
        "core/ui/bubble-combined.js",
        "auto/detection.js",
        "auto/input-handler.js",
        "auto/editable-handler.js",
        "manual/global-events.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "sound/notify.mp3"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}